{
	"name": "Notion MCP Server - Full Development Environment",
	"description": "Complete development environment for Notion MCP Server with AI agents, web interface, and all tools",
	
	// Use Docker Compose for full environment
	"dockerComposeFile": "../docker-compose.codespaces.yml",
	"service": "notion-dev",
	"workspaceFolder": "/workspace",
	
	// Alternative: Use custom Dockerfile
	// "dockerfile": "../Dockerfile.codespaces",
	
	// Features to add to the dev container
	"features": {
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {},
		"ghcr.io/devcontainers/features/common-utils:2": {
			"installZsh": true,
			"configureZshAsDefaultShell": true,
			"installOhMyZsh": true
		}
	},
	
	// Configure tool-specific properties
	"customizations": {
		"vscode": {
			"extensions": [
				// AI & Copilot
				"GitHub.copilot",
				"GitHub.copilot-chat",
				"ms-windows-ai-studio.windows-ai-studio",
				
				// TypeScript & Node.js
				"ms-vscode.vscode-typescript-next",
				"bradlc.vscode-tailwindcss",
				"esbenp.prettier-vscode",
				"ms-vscode.vscode-eslint",
				
				// Development Tools
				"ms-vscode.vscode-json",
				"redhat.vscode-yaml",
				"ms-vscode.powershell",
				
				// Docker
				"ms-azuretools.vscode-docker",
				
				// REST Client for API testing
				"humao.rest-client",
				
				// Notion
				"leodevbro.blockman",
				
				// Git
				"mhutchie.git-graph",
				"eamodio.gitlens"
			],
			"settings": {
				"typescript.preferences.importModuleSpecifier": "relative",
				"editor.formatOnSave": true,
				"editor.defaultFormatter": "esbenp.prettier-vscode",
				"editor.codeActionsOnSave": {
					"source.fixAll.eslint": true
				},
				"terminal.integrated.defaultProfile.linux": "zsh",
				"files.exclude": {
					"**/node_modules": true,
					"**/build": true,
					"**/dist": true
				}
			}
		}
	},
	
	// Forward ports for all services
	"forwardPorts": [3001, 3002, 8080, 5173, 6379],
	"portsAttributes": {
		"3001": {
			"label": "API Gateway",
			"onAutoForward": "notify"
		},
		"3002": {
			"label": "Web Chat Interface", 
			"onAutoForward": "openBrowser"
		},
		"8080": {
			"label": "MCP Server",
			"onAutoForward": "silent"
		},
		"5173": {
			"label": "Vite Dev Server",
			"onAutoForward": "silent"
		},
		"6379": {
			"label": "Redis",
			"onAutoForward": "silent"
		}
	},
	
	// Commands to run after container creation
	"postCreateCommand": "npm run setup && echo '🎉 Development environment ready!' && echo '📖 Quick start: npm run dev'",
	
	// Commands to run when container starts
	"postStartCommand": "echo '🚀 Container started! Run npm run dev to start all services'",
	
	// Commands to run when attaching to container
	"postAttachCommand": "echo '👋 Welcome to Notion MCP Server development environment!'",
	
	// Environment variables
	"containerEnv": {
		"NODE_ENV": "development",
		"GATEWAY_PORT": "3001",
		"WEB_PORT": "3002", 
		"MCP_PORT": "8080"
	},
	
	// Mount additional directories
	"mounts": [
		"source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
	],
	
	// Run as non-root user
	"remoteUser": "node",
	
	// Enable init process
	"init": true,
	
	// Override command to keep container running
	"overrideCommand": false
}
